# Copy this file to `.env` and fill in your own values.
# `.env` is git-ignored — never commit real keys.

# --- Database ---------------------------------------------------------------
# PostgreSQL connection string. On Vercel this is injected automatically when
# you attach a Postgres database; locally, paste that same string (or a
# separate dev database) here.
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# --- App --------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Admin auth (JWT) -------------------------------------------------------
# Generate a strong secret, e.g.  openssl rand -base64 32
JWT_SECRET=""
# Seed admin credentials (used by `npm run db:seed`)
ADMIN_EMAIL="admin@chrixlin.tech"
ADMIN_PASSWORD=""

# --- Razorpay ---------------------------------------------------------------
# Leave empty for DEV MOCK MODE: checkout completes without a real payment so
# the full enroll flow is testable. Add real keys to go live.
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""
NEXT_PUBLIC_RAZORPAY_KEY_ID=""

# --- Resend (email) ---------------------------------------------------------
# Leave empty in dev: emails are logged to the EmailLog table instead of sent.
RESEND_API_KEY=""
EMAIL_FROM="Chrixlin.tech Academy <onboarding@resend.dev>"

# --- Cron (email automation endpoint protection) ----------------------------
CRON_SECRET=""
